  langid = {english},
  keywords = {Accountability,Capacity building approach,Constraints,Consumers,Diabetes,Disorders,Drug use,Endorsements,Health behavior,Health care,Health care expenditures,Health care policy,Health insurance,Health services,Hypertension,Insurance coverage,Investments,Measurement,Measures,Medicaid,Medicare,Medicine,Mental depression,Mental disorders,Mental health,Mental health care,Mental health services,Patients,Quality assessment,Quality of care,Reforms,Research,Substance abuse,Substance use,Substance use disorder,Trends,Web portals,Workforce}
