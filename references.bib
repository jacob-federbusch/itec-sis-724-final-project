  title = {To What Extent Does Early Childhood Education Policy in {{Australia}} Recognise and Propose Action on the Social Determinants of Health and Health Equity?},
  author = {EYK, HELEN VAN and Baum, Fran and Fisher, Matt and MacDougall, Colin and Lawless, Angela},
  year = 2023,
