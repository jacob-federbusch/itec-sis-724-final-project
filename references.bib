  doi = {10.1007/s10597-021-00921-7},
  urldate = {2026-04-01},
  abstract = {Social determinants are receiving renewed attention as research demonstrates the effects of social factors on individuals' physical and mental health and elucidates the biological and psychological mechanisms underlying those effects. Through spheres of influence from policy and regulation development to direct service provision, state mental health agencies are in a unique position to lead primary and secondary prevention efforts aimed at addressing social determinants with both client-level and structural-level interventions. A survey of social determinants-related activity was sent to the Medical Directors of the state offices of mental health in all 50 states. The survey results suggest consensus among respondents as to the importance of addressing specific social determinants. However, few state mental health agencies have taken on a comprehensive and intentional approach to addressing social determinants as a unique area of activity. Specific activities are reviewed, and implications for future work is discussed.},
