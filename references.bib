  shorttitle = {6.{{I}}. {{Scientific}} Session},
  author = {{section}, EUPHA Public Mental Health and {Chair persons: Birgitte Blatter (Netherlands)}, Jutta Lindert (EUPHA-PMH)},
  year = 2025,
