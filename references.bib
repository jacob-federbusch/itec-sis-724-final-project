@article{caveCaregiverperceivedRacialDiscrimination2019,
  title = {Caregiver-Perceived Racial Discrimination Is Associated with Diverse Mental Health Outcomes in {{Aboriginal}} and {{Torres Strait Islander}} Children Aged 7--12\,Years},
  author = {Cave, Leah and Cooper, Matthew N. and Zubrick, Stephen R. and Shepherd, Carrington C. J.},
  year = 2019,
  journal = {International Journal for Equity in Health},
  volume = {18},
  publisher = {Springer Nature B.V.},
  address = {London, Netherlands},
  doi = {10.1186/s12939-019-1045-8},
  urldate = {2026-04-01},
  abstract = {Background Racial discrimination is acknowledged as a central social determinant of Australian Aboriginal and Torres Strait Islander (hereafter referred to as Aboriginal) health, although quantitative empirical literature on the impacts of racism on Aboriginal children remains sparse. We use a novel, longitudinal dataset to explore the relationship between caregiver-perceived racism exposure and a range of mental health and related behavioural and physiological outcomes in childhood. Method The study cohort comprised 1759 Aboriginal children aged 4--12 years from waves 2--8 (2009--2015) of the Footprints in Time: The Longitudinal Study of Indigenous Children (LSIC) dataset. We examined exposure to caregiver-perceived racism between 4 and 11 years as a predictor for mental health and related outcomes at ages 7--12 and substance use at 10--12 years. Unadjusted models and models adjusted for remoteness, community-level and family-level socio-economic status, child age and gender were used in analysis. Multilevel logistic regression was used in all analysis. Results In fully adjusted models, perceived exposure to racism at ages 4--11 was associated with twice the risk of negative mental health (95\% CI: 1.3--3.0), sleep difficulties (95\% CI: 1.4--3.0), and behaviour issues at school (95\% CI: 1.2--2.9), 1.7 times the risk of obesity (95\% CI: 1.1--2.5), and nearly 7 times the risk of trying cigarettes (95\% CI: 1.1--43.9). Increased risks were also found for being underweight and trying alcohol though estimates did not reach statistical significance. There was no evidence that racism was associated with poorer general health. Conclusion Exposure to racial discrimination in Aboriginal children increased the risk for a spectrum of interrelated psychological, behavioural and physiological factors linked to negative mental health. Our results further affirm the importance of interventions aimed at reducing the prevalence of racial discrimination for the benefits of population health and health inequalities. The services and institutions which aim to support the mental health and wellbeing of Aboriginal children should also support interventions to reduce racism and implement accountable policies which prioritise this goal.},
  chapter = {Research},
  copyright = {\copyright{} 2019. This work is licensed under http://creativecommons.org/licenses/by/4.0/  (the ``License'').  Notwithstanding the ProQuest Terms and Conditions, you may use this content in accordance with the terms of the License.},
  langid = {english},
  keywords = {Aboriginal,Aboriginal Australians,Aborigine,Age,Alcoholic beverages,Anatomical systems,Australia,Caregivers,Child,Child development,Childhood,Children,Children & youth,Cigarette,Cigarettes,Correlation analysis,Datasets,Discrimination,Drug use,Economic analysis,Economic models,Economic status,Empirical analysis,Exposure,Health behavior,Health disparities,Health status,Indigenous Australians,Indigenous peoples,Inequality,Intervention,Longitudinal studies,Mental disorders,Mental health,Mental health services,Models,Native peoples,Novels,Obesity,Physiological factors,Physiology,Population,Racial discrimination,Racism,Regression analysis,Risk,Sleep,Smoking,Social determinants of health,Socioeconomic factors,Socioeconomic status,Socioeconomics,Statistical analysis,Statistical significance,Substance,Substance abuse,Substance use,Time,Underweight,Well being},
  file = {C:\Users\jakef\Zotero\storage\I9YSI9ZU\Cave et al. - 2019 - Caregiver-perceived racial discrimination is associated with diverse mental health outcomes in Abori.pdf}
}

@phdthesis{chibaniUnravelingPolicyChallenges2025,
  title = {Unraveling {{Policy Challenges}} for {{Behavioral Health Providers}}' {{Participation}} in {{Insurance Networks}}},
  author = {Chibani, Doha},
  year = 2025,
  address = {United States -- Maryland},
  urldate = {2026-04-01},
  abstract = {Persistent disparities between behavioral health and medical insurance coverage remain, despite decades of parity legislation. With one in five Americans experiencing mental illness, insurance expansions have failed to eliminate systemic barriers to treatment. This reflexive thematic analysis study analyzed how federal and Maryland parity policies impact mental health providers by examining the experiences of 25 licensed behavioral health clinicians of diverse demographics through semi-structured interviews. An integrated theoretical framework, combining Levesque's healthcare access model, social determinants of health, and economic market failure theory, guided the analysis of factors influencing provider network participation. Six systemic barriers emerged: (1) overwhelming administrative burden due to credentialing delays, claims errors, and complex authorizations; (2) persistent rate suppression, with reimbursement way below private pay; (3) clinical autonomy erosion through session/time restrictions and mandatory protocols; (4) tiered reimbursement disparities affecting psychiatrists, nurse practitioners, psychologists, and therapists differently; (5) workforce shortages disproportionately limiting access for marginalized and high-needs populations; and (6) enforcement failures within state insurance administration oversight, where parity violations are ineffectively penalized. These barriers have driven a third of participants to exit all insurance networks, with mission-driven equity efforts undermined by unsustainable financial and administrative burdens. Therapists faced unique coding and unpaid labor challenges, while prescribers reported crisis care delays and formulary limitations. Economic analysis revealed insurers' market power to limit network participation and shift operational expenses onto clinicians, despite reported network sufficiency and long appointment waitlists. Policy recommendations include: (1) capping credentialing days with automatic approval, (2) raising behavioral health reimbursements to at least 80\% of market rates, (3) protecting clinical autonomy from non-expert review, (4) incentivizing workforce diversity and retention through loan repayment, (5) requiring public fee schedule transparency and prohibiting gag clauses, (6) establishing independent enforcement authorities, and (7) developing universal portals for credentialing and claims. Without robust and coordinated federal and state reforms addressing entrenched administrative, economic, and oversight barriers, parity will remain unmet, perpetuating a two-tiered system with quality behavioral care accessible only to those able to pay out of pocket, while insured networks face persistent churn and inexperience.},
  copyright = {Database copyright ProQuest LLC; ProQuest does not claim copyright in the individual underlying works.},
  isbn = {9798270236878},
  langid = {english},
  school = {University of Maryland, Baltimore County},
  keywords = {Behavioral health policy,Behavioral psychology,Health care management,Mental health,Mental health access,Mental health parity,Provider network participation,Public policy,Reimbursement rates},
  file = {C:\Users\jakef\Zotero\storage\BRGTZVRF\Chibani - 2025 - Unraveling Policy Challenges for Behavioral Health Providers’ Participation in Insurance Networks.pdf}
}

